<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_security_settings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.security.SecuritySettingsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Encryption Keys Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/encryption_keys"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="?attr/dividerColor" />

                    <!-- Master Password -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/master_password"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/master_password_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/master_password_not_set"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Keystore Backup -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/keystore_backup"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/last_synced_timestamp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/keystore_never"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />

                            <Button
                                android:id="@+id/sync_keystore_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sync_now" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <Button
                                android:id="@+id/export_keystore_button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/export_keystore" />

                            <Button
                                android:id="@+id/restore_keystore_button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/restore_from_telegram"
                                android:layout_marginStart="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Biometric Lock -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/biometric_lock"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textStyle="bold" />

                        <Switch
                            android:id="@+id/biometric_toggle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/require_fingerprint_before_decrypting"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- Danger Zone -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/danger_zone"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/clear_keys_button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/clear_all_local_keys"
                            android:textColor="?attr/colorError"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="?attr/colorError" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>